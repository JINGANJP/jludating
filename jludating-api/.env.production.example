# ============================================
# JLUDating 生产环境配置
# ============================================
# 重要：请勿将真实密钥提交到代码仓库！
# 推荐使用环境变量或密钥管理服务

# 数据库 (PostgreSQL)
# 推荐使用 Supabase、Railway 或 Neon 的免费 PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/jludating

# Redis
# 推荐使用 Upstash Redis 免费额度
REDIS_URL=redis://host:6379

# JWT 密钥 (必须至少32字符)
# 使用 openssl rand -base64 32 或 node -e "console.log(require('crypto').randomBytes(32).toString('base64'))" 生成
JWT_SECRET=4Dak1Rrmlfx+pDAf8KsHEszkr3tZ8wUTUMVvN+DOVOQ=
JWT_EXPIRES_IN=15m

# 前端 URL (生产环境)
# 部署到 Vercel 后填写你的 Vercel 域名
FRONTEND_URL=https://your-app.vercel.app,http://localhost:5173

# 邮件服务 (保持不变)
MAIL_HOST=smtp.163.com
MAIL_PORT=465
MAIL_USER=15922830971@163.com
MAIL_PASS=your_mail授权码
MAIL_FROM=JLUDating <15922830971@163.com>

# 服务器配置
APP_PORT=3000
NODE_ENV=production
